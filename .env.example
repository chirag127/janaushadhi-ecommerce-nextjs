# ==========================================================================
# Jan Aushadhi Ecommerce — Environment Variables (InsForge)
# --------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in your InsForge credentials.
# Get values with the InsForge CLI:
#   URL      -> "oss_host" in .insforge/project.json
#   ANON_KEY -> npx @insforge/cli secrets get ANON_KEY
# Only NEXT_PUBLIC_* variables are exposed to the browser. The anon key is
# safe to expose; all data access is protected by row-level security (RLS).
# ==========================================================================

# InsForge project URL (required)
NEXT_PUBLIC_INSFORGE_URL=https://your-project.us-east.insforge.app

# InsForge anon (publishable) key — safe in the browser (required)
NEXT_PUBLIC_INSFORGE_ANON_KEY=anon_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public site origin — used for SEO metadata, sitemap, and OAuth redirects.
# Local dev: http://localhost:3000  |  Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Razorpay test mode. "true" keeps Checkout in test env; set "false" for live.
# Keys themselves are configured backend-side on InsForge, not here:
#   npx @insforge/cli payments razorpay config set \
#     --environment test --key-id rzp_test_xxx --key-secret xxx
# COD works without any Razorpay keys.
NEXT_PUBLIC_RAZORPAY_TEST_MODE=true
